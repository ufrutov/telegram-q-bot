{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/cron/daily-question",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ]
}
