{
  "name": "telegram-q-bot",
  "version": "1.0.15",
  "description": "Telegram Question Bot - A Telegram bot deployed on Vercel",
  "main": "dist/api/webhook.js",
	"scripts": {
		"build": "tsc && tsc-alias && find dist -name '*.js' -exec sed -i -E 's~\"(\\.\\./)((\\.\\./)+)src/~\"\\2src/~g' {} + && find dist -type f \\( -name '*.d.ts' -o -name '*.d.ts.map' -o -name '*.js.map' \\) -delete",
		"dev": "tsx watch api/webhook.ts",
		"type-check": "tsc --noEmit",
		"lint": "oxlint src api",
		"format": "oxfmt --write src api",
		"format:check": "oxfmt --check src api",
		"test": "echo \"Error: no test specified\" && exit 1",
		"test:loaders": "tsx src/lib/QuestionLoader/test/test-loaders.ts",
		"test:got-questions": "tsx src/lib/QuestionLoader/test/test-got-questions.ts"
	},
  "keywords": [
    "telegram",
    "bot",
    "vercel",
    "webhook"
  ],
  "author": "",
  "license": "ISC",
	"engines": {
		"node": "22.x"
	},
  "dependencies": {
    "dotenv": "^17.4.1",
    "node-telegram-bot-api": "^0.67.0",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@vercel/node": "^5.8.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
